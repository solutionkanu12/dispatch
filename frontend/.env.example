# Only needed if the backend (server/server.ts) is running on a port other
# than its default of 3000 (see .env.example at the repo root / server.ts's
# PORT env var). The dev server proxies /api/* to this URL; see vite.config.js.
# Not used in a production build; that build has no dev proxy at all.
VITE_BACKEND_URL=http://localhost:3000

# Required in production (e.g. deployed to Vercel). There is no dev proxy in
# a static build, so every API call is built as an absolute URL against this.
# Leave unset for local dev; src/lib/apiUrl.js falls back to a relative path,
# which VITE_BACKEND_URL above proxies correctly.
VITE_API_URL=https://your-backend.example.com
