DATABASE_URL=postgres://user:password@localhost:5432/dispatch
PORT=3000

# Base URL of the running cap-service process (cap-service/main.py), which
# holds the real croo SDK client. Defaults to http://127.0.0.1:8001 if unset.
CAP_SERVICE_URL=http://127.0.0.1:8001

# The real CROO service_id each seeded agent (config/agents.json) negotiates
# with. Not the same value as agents.json's id or store_url. Required for a
# real POST /api/dispatch to place a real order for that agent; see
# scripts/verify_cap.py and scripts/verify_chainguard.py for how these are
# obtained. Without these set, placement fails cleanly with a clear reason.
CROO_VERIMATH_SERVICE_ID=
CROO_CHAINGUARD_SERVICE_ID=
